# Super-Linter Configuration
# See: https://github.com/super-linter/super-linter
#
# When VALIDATE_* variables are set, super-linter runs in "inclusion mode":
# only the listed linters run — all others are automatically disabled.
#
# DESIGN PRINCIPLE: One linter per file type, except where two tools are complementary.
# - JSON     → VALIDATE_JSON_PRETTIER (prettier validates syntax + formatting)
# - YAML     → VALIDATE_YAML_PRETTIER (prettier validates syntax + formatting)
# - Markdown → VALIDATE_MARKDOWN (markdownlint: rules/structure + formatting)
# - Shell    → VALIDATE_BASH (shellcheck) + VALIDATE_SHELL_SHFMT (shfmt) — complementary

# ===== LANGUAGE-AGNOSTIC LINTERS (ALWAYS ENABLED) =====
VALIDATE_BASH=true
VALIDATE_BASH_EXEC=true
VALIDATE_EDITORCONFIG=true
VALIDATE_GIT_COMMITLINT=true
VALIDATE_GIT_MERGE_CONFLICT_MARKERS=true
VALIDATE_JSON_PRETTIER=true
VALIDATE_MARKDOWN=true
VALIDATE_NATURAL_LANGUAGE=true
VALIDATE_PRE_COMMIT=true
VALIDATE_SHELL_SHFMT=true
VALIDATE_XML=true
VALIDATE_YAML_PRETTIER=true

# ===== AUTO-FIX SETTINGS =====
# Used by 'make lint-fix'. Only effective when the volume is mounted read-write (not :ro).
FIX_JSON_PRETTIER=true
FIX_SHELL_SHFMT=true
FIX_YAML_PRETTIER=true

# ===== LANGUAGE-SPECIFIC LINTERS =====
# Uncomment the linters for your project's languages.
# The create-repository workflow enables these automatically based on your language selection.

# JavaScript / TypeScript / Node.js
# VALIDATE_JAVASCRIPT_ES=true
# VALIDATE_JAVASCRIPT_PRETTIER=true
# VALIDATE_TYPESCRIPT_ES=true
# VALIDATE_TYPESCRIPT_PRETTIER=true
# VALIDATE_JSX=true
# VALIDATE_JSX_PRETTIER=true
# VALIDATE_TSX=true
# FIX_JAVASCRIPT_ES=true
# FIX_JAVASCRIPT_PRETTIER=true
# FIX_TYPESCRIPT_ES=true
# FIX_TYPESCRIPT_PRETTIER=true
# FIX_JSX_PRETTIER=true
# FIX_TSX=true

# Python
VALIDATE_PYTHON_RUFF=true
VALIDATE_PYTHON_RUFF_FORMAT=true
VALIDATE_PYTHON_MYPY=true
FIX_PYTHON_RUFF=true
FIX_PYTHON_RUFF_FORMAT=true

# Java
# VALIDATE_JAVA=true
# VALIDATE_GOOGLE_JAVA_FORMAT=true
# FIX_GOOGLE_JAVA_FORMAT=true

# Go
# VALIDATE_GO=true
# VALIDATE_GO_MODULES=true

# Rust  (use standard image; excluded from slim)
# VALIDATE_RUST_2021=true
# VALIDATE_RUST_CLIPPY=true

# Ruby
# VALIDATE_RUBY=true
# FIX_RUBY=true

# PHP
# VALIDATE_PHP_BUILTIN=true
# VALIDATE_PHP_PHPCS=true
# FIX_PHP_PHPCS=true

# C# / .NET  (use standard image; excluded from slim)
# VALIDATE_CSHARP=true

# C / C++
# VALIDATE_CPP=true
# VALIDATE_CLANG_FORMAT=true
# FIX_CLANG_FORMAT=true

# Web (CSS/HTML)
# VALIDATE_CSS=true
# VALIDATE_CSS_PRETTIER=true
# VALIDATE_HTML=true
# VALIDATE_HTML_PRETTIER=true
# FIX_CSS_PRETTIER=true
# FIX_HTML_PRETTIER=true

# Infrastructure as Code
# VALIDATE_DOCKERFILE_HADOLINT=true
# VALIDATE_KUBERNETES_KUBECONFORM=true
# VALIDATE_TERRAFORM_FMT=true
# VALIDATE_TERRAFORM_TFLINT=true
# FIX_TERRAFORM_FMT=true

# Other Languages
# VALIDATE_KOTLIN=true
# VALIDATE_GROOVY=true
# VALIDATE_OPENAPI=true

# Security scanning (may require additional configuration)
# VALIDATE_GITLEAKS=true
# VALIDATE_CHECKOV=true
# VALIDATE_TRIVY=true
